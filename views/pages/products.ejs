<%- include('../partials/head', {title:'Menu', bodyClass:'sub_page'}) %>
<%- include('../partials/header') %>

<section class="food_section layout_padding">
  <div class="container">
    <div class="heading_container heading_center">
      <h2>Our Menu</h2>
    </div>

    <ul class="filters_menu">
      <li class="active" data-filter="*">All</li>
      <li data-filter=".burger">Burger</li>
      <li data-filter=".pizza">Pizza</li>
      <li data-filter=".pasta">Pasta</li>
      <li data-filter=".fries">Fries</li>
    </ul>

    <div class="filters-content">
      <div class="row grid">
        <% const products = result || []; %>
        <% if (products.length) { %>
          <% products.forEach(function(item) { %>
            <div class="col-sm-6 col-lg-4 all <%= item.category || 'pizza' %>">
              <div class="box">
                <div>
                  <div class="img-box">
                    <img src="/images/<%= item.image %>" alt="<%= item.name %>" />
                  </div>
                  <div class="detail-box">
                    <span class="item-tag"><%= (item.category || 'Menu').charAt(0).toUpperCase() + (item.category || 'Menu').slice(1) %></span>
                    <h5><a href="/single_product?id=<%= item.id %>" style="color:#fff;"><%= item.name %></a></h5>
                    <p><%= item.description %></p>
                    <div class="options">
                      <% if (item.sale_price) { %>
                        <h6>$<%= item.sale_price %></h6>
                        <h6 style="text-decoration:line-through;">$<%= item.price %></h6>
                      <% } else { %>
                        <h6>$<%= item.price %></h6>
                      <% } %>
                      <form action="/add_to_cart" method="post" style="margin-top: 12px;">
                        <input type="hidden" name="id" value="<%= item.id %>" />
                        <input type="hidden" name="name" value="<%= item.name %>" />
                        <input type="hidden" name="price" value="<%= item.price %>" />
                        <input type="hidden" name="sale_price" value="<%= item.sale_price %>" />
                        <input type="hidden" name="quantity" value="1" />
                        <input type="hidden" name="image" value="<%= item.image %>" />
                        <button class="order_online" type="submit">Add to Cart</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="col-12 text-center"><p>No menu items currently available.</p></div>
        <% } %>
      </div>
      <div class="btn-box text-center mt-4">
        <a href="/" class="btn1">Other Meals</a>
      </div>
    </div>
  </section>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
