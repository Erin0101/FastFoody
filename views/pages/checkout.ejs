<%- include('../partials/head', {title:'Checkout', bodyClass:'sub_page'}) %>
<%- include('../partials/header') %>

<section class="checkout_section layout_padding">
  <div class="container">
    <div class="heading_container heading_center">
      <h2>Checkout</h2>
      <p>Complete your order with fast checkout and secure payment details.</p>
    </div>
    <div class="row justify-content-center">
      <div class="col-lg-7">
        <form id="checkout-form" method="post" action="/place_order" class="checkout-form">
          <div class="form-group checkout-small-element">
            <label>Name</label>
            <input type="text" class="form-control" id="checkout-name" name="name" placeholder="Name" required />
          </div>
          <div class="form-group checkout-small-element">
            <label>Email</label>
            <input type="email" class="form-control" id="checkout-email" name="email" placeholder="Email address" required />
          </div>
          <div class="form-group checkout-small-element">
            <label>Phone</label>
            <input type="tel" class="form-control" id="checkout-phone" name="phone" placeholder="Phone number" required />
          </div>
          <div class="form-group checkout-small-element">
            <label>City</label>
            <input type="text" class="form-control" id="checkout-city" name="city" placeholder="City" required />
          </div>
          <div class="form-group checkout-large-element">
            <label>Address</label>
            <input type="text" class="form-control" id="checkout-address" name="address" placeholder="Address" required />
          </div>
          <div class="form-group checkout-btn-container">
            <button type="submit" class="btn" id="checkout-btn" name="checkout_btn">Place Order</button>
          </div>
        </form>
      </div>
      <div class="col-lg-4">
        <div class="checkout-summary-card">
          <h4>Order Summary</h4>
          <p>Total due</p>
          <strong>$<%= total || 0 %></strong>
          <p class="checkout-note">We will contact you when your order is ready for delivery.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>
